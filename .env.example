# =============================================================================
# weka-over-mcp — environment reference
# =============================================================================
# The local compose.yaml already sets sane defaults inline, so you do NOT need a
# .env file to run locally. This file documents every variable the two services
# read (from source) and the parameters the Azure deploy scripts consume.
#
# Copy to .env only if you want to override compose defaults, or export the
# AZURE_* / INTERNAL_AUTH_SHARED_SECRET values before running the deploy scripts.

# --- weka-api (Java/Javalin) — read in weka-api/src/main/java/.../config/Config.java
PORT=7070                     # HTTP port Javalin binds
MODELS_DIR=/app/models        # serialized .model files
DATA_DIR=/app/data            # uploaded ARFF/CSV datasets
MAX_UPLOAD_MB=100             # upload size cap (MB)
LOG_LEVEL=INFO                # logback root level
# No JVM heap flag in the Dockerfile; set one under a container memory cap:
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0

# --- weka-mcp (TypeScript/Node) — read in weka-mcp/src/{config.ts,client.ts}
WEKA_API_URL=http://localhost:7070   # base URL of weka-api (compose: http://weka-api:7070)
MCP_HTTP_PORT=3000                   # port the MCP HTTP transport listens on (POST /mcp)
WEKA_API_TIMEOUT_MS=210000           # per-request timeout to weka-api (< ~240s Envoy ceiling)
# Host ports compose publishes the two services on (containers are always 3000 /
# 7070 internally). Defaults avoid clashing with other local stacks. `bin/setup`
# auto-selects free ports and writes these two keys into a generated .env for you;
# set them here only to override the manual `docker compose up` path.
MCP_HOST_PORT=3001            # hit /mcp at localhost:$MCP_HOST_PORT
WEKA_API_HOST_PORT=7070       # direct weka-api access at localhost:$WEKA_API_HOST_PORT
# Shared secret for the X-Internal-Auth header on POST /mcp. UNSET locally (auth
# skipped). MANDATORY in the cloud because weka-mcp has public ingress there.
# INTERNAL_AUTH_SHARED_SECRET=

# --- Azure deploy (infrastructure/scripts/*.sh) ---
AZURE_RESOURCE_GROUP=weka-mcp-rg
AZURE_LOCATION=eastus
AZURE_NAME_PREFIX=wekamcp        # base name for ACR / env / apps (lowercase, alnum)
# INTERNAL_AUTH_SHARED_SECRET is generated by deploy.sh if unset and printed once.
